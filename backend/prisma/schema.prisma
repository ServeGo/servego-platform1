generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String         @id @default(cuid())
  name                    String
  email                   String         @unique
  phone                   String
  role                    UserRole
  password                String
  avatar                  String?
  status                  AccountStatus  @default(ACTIVE)
  address                 String?
  pincode                 String?
  referralCode            String?
  referralsCount          Int            @default(0)
  referralDiscountBalance Float          @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  authEvents              AuthEvent[]
  bookingsAsCustomer      Booking[]      @relation("CustomerBookings")
  notifications           Notification[]
  payments                Payment[]
  providerProfile         Provider?
  reviews                 Review[]       @relation("ReviewerReviews")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("SYSTEM")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Ticket {
  id             String       @id @default(cuid())
  requesterName  String
  requesterEmail String
  subject        String
  message        String
  status         TicketStatus @default(OPEN)
  adminResponse  String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AuthEvent {
  id        String        @id @default(cuid())
  userId    String?
  email     String
  eventType AuthEventType
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime      @default(now())
  user      User?         @relation(fields: [userId], references: [id])
}

model Provider {
  id                String    @id @default(cuid())
  userId            String    @unique
  category          String
  rating            Float     @default(4.8)
  reviewCount       Int       @default(0)
  experienceYears   Int       @default(3)
  jobsCompleted     Int       @default(0)
  hourlyRate        Float     @default(300)
  bio               String?
  specialties       Json      @default("[]")
  serviceAreas      Json      @default("[]")
  photo             String?
  serviceInterested String?
  isVerified        Boolean   @default(true)
  isFeatured        Boolean   @default(false)
  availableDays     Json      @default("[]")
  timeSlots         Json      @default("[]")
  earnings          Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  bookings          Booking[]
  user              User      @relation(fields: [userId], references: [id])
  reviews           Review[]  @relation("ProviderReviews")
  services          Service[]
}

model Service {
  id            String    @id @default(cuid())
  name          String
  description   String?
  basePrice     Float     @default(0)
  popularIssues Json      @default("[]")
  isHidden      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  providerId    String?
  bookings      Booking[]
  provider      Provider? @relation(fields: [providerId], references: [id])
}

model Booking {
  id              String        @id @default(cuid())
  customerId      String
  providerId      String
  serviceId       String?
  serviceCategory String
  bookingDate     DateTime
  bookingTimeSlot String
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String?
  locationAddress String
  city            String
  instructions    String?
  totalAmount     Float
  tax             Float         @default(0)
  serviceFee      Float         @default(0)
  invoiceNumber   String?
  bookingTime     DateTime
  messages        Json          @default("[]")
  reviewed        Boolean       @default(false)
  statusHistory   Json          @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customer        User          @relation("CustomerBookings", fields: [customerId], references: [id])
  provider        Provider      @relation(fields: [providerId], references: [id])
  service         Service?      @relation(fields: [serviceId], references: [id])
  payment         Payment?
  reviews         Review[]
}

model Review {
  id              String   @id @default(cuid())
  reviewerId      String
  providerId      String
  bookingId       String?
  rating          Float
  comment         String?
  date            DateTime @default(now())
  serviceCategory String?
  createdAt       DateTime @default(now())
  booking         Booking? @relation(fields: [bookingId], references: [id])
  provider        Provider @relation("ProviderReviews", fields: [providerId], references: [id])
  reviewer        User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  userId        String
  amount        Float
  currency      String        @default("INR")
  paymentMethod String
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
}

enum UserRole {
  customer
  provider
  admin
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AuthEventType {
  SIGNUP
  LOGIN
  LOGOUT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum PaymentStatus {
  PENDING
  UNPAID
  PAID
  FAILED
}

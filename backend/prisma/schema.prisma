generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String         @id @default(cuid())
  name                    String
  email                   String         @unique
  phone                   String
  role                    UserRole
  password                String
  avatar                  String?
  status                  AccountStatus  @default(ACTIVE)
  address                 String?
  pincode                 String?
  referralCode            String?
  referredBy              String?
  referralsCount          Int            @default(0)
  referralDiscountBalance Float          @default(0)
  referralBonusEarned     Float          @default(0)
  providerId              String?
  profileComplete         Boolean        @default(false)

  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  // Indexes for common queries
  @@index([role])
  @@index([status])
  @@index([email])
  @@index([providerId])
  @@index([createdAt])

  authEvents              AuthEvent[]
  bookingsAsCustomer      Booking[]      @relation("CustomerBookings")
  notifications           Notification[]
  payments                Payment[]
  providerProfile         Provider?
  customerProfile         Customer?
  reviews                 Review[]       @relation("ReviewerReviews")
  savedPros               SavedPro[]
}

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique
  address   String
  pincode   String
  preferences Json    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id               String   @id @default(cuid())
  userId           String
  title            String
  message          String
  type             String   @default("SYSTEM")
  isRead           Boolean  @default(false)
  relatedBookingId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Indexes for common queries
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])

  user      User     @relation(fields: [userId], references: [id])
}

model Ticket {
  id               String       @id @default(cuid())
  userId           String?
  requesterName    String
  requesterEmail   String
  subject          String
  message          String
  status           TicketStatus @default(OPEN)
  adminResponse    String?
  relatedBookingId String?
  resolvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Indexes for common queries
  @@index([status])
  @@index([requesterEmail])
  @@index([userId])
  @@index([createdAt])
}

model AuthEvent {
  id        String        @id @default(cuid())
  userId    String?
  email     String
  eventType AuthEventType
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime      @default(now())
  user      User?         @relation(fields: [userId], references: [id])
}

model Provider {
  id                String    @id @default(cuid())
  userId            String    @unique
  category          String
  rating            Float     @default(0)
  reviewCount       Int       @default(0)
  verificationLevel VerificationLevel @default(BRONZE)
  accountStatus     ProviderAccountStatus @default(ACTIVE)
  profileComplete   Boolean   @default(false)

  experienceYears   Int       @default(3)
  jobsCompleted     Int       @default(0)
  bio               String?
  specialties       Json      @default("[]")
  serviceAreas      Json      @default("[]")
  photo             String?
  serviceInterested String?
  isVerified        Boolean   @default(true)
  isFeatured        Boolean   @default(false)
  availableDays     Json      @default("[]")
  timeSlots         Json      @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Indexes for common queries
  @@index([userId])
  @@index([category])
  @@index([rating])
  @@index([isVerified])
  @@index([isFeatured])
  @@index([createdAt])

  bookings          Booking[]
  user              User      @relation(fields: [userId], references: [id])
  reviews           Review[]  @relation("ProviderReviews")
  badges            ProviderBadge[]
  savedByCustomers  SavedPro[]

  providerServices        ProviderService[]
  providerServiceRequests ProviderServiceRequest[]
  availabilitySlots       AvailabilitySlot[]
}

model ProviderBadge {
  id         String    @id @default(cuid())
  providerId String
  badgeType  BadgeType
  awardedAt  DateTime  @default(now())

  provider   Provider  @relation(fields: [providerId], references: [id])

  @@unique([providerId, badgeType])
}

model Service {
  id             String         @id @default(cuid())
  name           String
  nameNormalized String?        @unique
  description    String?

  popularIssues  Json           @default("[]")
  isHidden       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  bookings       Booking[]
  providerServices ProviderService[]
}

// Provider’s approved global services
model ProviderService {
  id          String   @id @default(cuid())
  providerId  String
  serviceId   String
  description String?
  providerServiceRequestId String? // if this link was created from an approval request
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider          Provider @relation(fields: [providerId], references: [id])
  service           Service  @relation(fields: [serviceId], references: [id])

  providerServiceRequests ProviderServiceRequest[]

  @@unique([providerId, serviceId])
  @@unique([providerServiceRequestId])
}

// Provider’s pending/denied service registration request
model ProviderServiceRequest {
  id                    String        @id @default(cuid())
  providerId            String
  requestedServiceName String
  /// The Service that this request was created/approved against.
  /// Backfilled from requestedServiceName.
  requestedServiceId   String?
  description           String
  popularIssues        Json          @default("[]")
  experienceYears      Int?
  status                ApprovalStatus @default(PENDING)
  denialReason         String?
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  provider              Provider @relation(fields: [providerId], references: [id])
  providerServices     ProviderService[]
}


model Booking {
  id              String        @id @default(cuid())
  customerId      String
  providerId      String
  serviceId       String?
  serviceCategory String
  bookingDate     DateTime
  bookingTimeSlot String
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String?
  locationAddress String
  city            String
  instructions    String?

  cancelledBy     String?
  cancelledReason String?
  scheduledStart  DateTime?
  durationType    DurationType  @default(CONTRACT)
  durationYears   Int           @default(0)
  durationDays    Int           @default(1)
  durationHours   Int           @default(0)
  amount          Float?

  bookingTime     DateTime
  messages        Json          @default("[]")
  reviewed        Boolean       @default(false)
  statusHistory   Json          @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Indexes for common queries
  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@index([bookingDate])
  @@index([paymentStatus])
  @@index([serviceCategory])
  @@index([createdAt])
  @@index([customerId, status])
  @@index([providerId, status])

  customer        User          @relation("CustomerBookings", fields: [customerId], references: [id])
  provider        Provider      @relation(fields: [providerId], references: [id])
  service         Service?      @relation(fields: [serviceId], references: [id])
  payment         Payment?
  reviews         Review[]
  events          BookingEvent[]
}

model BookingEvent {
  id         String   @id @default(cuid())
  bookingId  String
  actorRole  String
  actorId    String?
  action     String
  note       String?
  createdAt  DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([createdAt])
}

model Review {
  id              String   @id @default(cuid())
  reviewerId      String
  reviewerName    String?
  providerId      String
  bookingId       String?
  rating          Float
  comment         String?
  date            DateTime @default(now())
  serviceCategory String?
  createdAt       DateTime @default(now())
  booking         Booking? @relation(fields: [bookingId], references: [id])
  provider        Provider @relation("ProviderReviews", fields: [providerId], references: [id])
  reviewer        User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])

  @@unique([bookingId])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  userId        String
  paymentMethod String
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
}

enum UserRole {
  customer
  provider
  admin
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_HOLD
  BLOCKED
}

enum AuthEventType {
  SIGNUP
  LOGIN
  LOGOUT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum PaymentStatus {
  PENDING
  UNPAID
  PAID
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  REJECTED
}

enum DurationType {
  CONTRACT
  PERMANENT
}

enum VerificationLevel {
  BRONZE
  SILVER
  GOLD
  ELITE
}

enum ProviderAccountStatus {
  ACTIVE
  ON_HOLD
  BLOCKED
}

model AvailabilitySlot {
  id         String   @id @default(cuid())
  providerId String
  dayOfWeek  String
  startTime  String
  endTime    String

  provider   Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, dayOfWeek, startTime])
  @@index([providerId])
}

model SavedPro {
  id         String   @id @default(cuid())
  customerId String
  providerId String
  createdAt  DateTime @default(now())

  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([customerId, providerId])
  @@index([customerId])
  @@index([providerId])
}

enum BadgeType {
  TOP_RATED
  FAST_RESPONSE
  JOBS_100
  RELIABLE_PROVIDER
  MULTI_SERVICE_EXPERT
  CUSTOMER_FAVORITE
  ELITE_PROVIDER
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String
  action     String
  targetType String
  targetId   String
  oldValue   Json?
  newValue   Json?
  ip         String?
  createdAt  DateTime @default(now())
}

